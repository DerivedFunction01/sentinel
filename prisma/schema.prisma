// SentinelPrompt — Prisma schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String?
  password     String // bcrypt hash
  role         String         @default("USER") // UserRole enum: USER | CUSTOMER_ADMIN | SUPER_ADMIN
  company      String?
  scanTokens   Int            @default(10)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  tokenRequests TokenRequest[]
  scans         Scan[]
  apiKeys       ApiKey[]
  emails        EmailLog[]
}

model TokenRequest {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Int // tokens requested
  reason     String?
  plan       String?   // pricing plan id, e.g. "starter" | "pro" | "enterprise"
  status     String    @default("PENDING") // TokenRequestStatus enum: PENDING | APPROVED | DENIED
  adminNote  String?
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  resolvedBy String? // admin user id
}

model Scan {
  id                String   @id @default(cuid())
  reportId          String   @unique // human-readable, e.g. "SP-26-0617-3Q91"
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetModel       String   // OpenRouter model id, e.g. "anthropic/claude-3.5-haiku"
  systemPrompt      String
  forbiddenTask     String
  judgeInstructions String
  tools             String   // JSON: ToolDef[]
  mockToolResponses String   // JSON: Record<string, unknown>
  trials            String   // JSON: Trial[]
  score             Int      @default(0)
  riskLevel         String   @default("LOW") // RiskLevel enum
  totalTrials       Int      @default(0)
  breaches          Int      @default(0)
  breachRate        Int      @default(0)
  summary           String   @default("")
  summaryDetail     String   @default("")
  status            String   @default("COMPLETED") // ScanStatus enum
  createdAt         DateTime @default(now())

  @@index([userId])
}

// Models fetched from OpenRouter's /api/v1/models endpoint.
// The ModelSelector dropdown queries this table instead of a hardcoded enum.
model Model {
  id              String   @id // OpenRouter model id, e.g. "openai/gpt-4"
  name            String   // Display name, e.g. "GPT-4"
  description     String?
  contextLength   Int?
  modality        String?  // e.g. "text->text"
  promptPrice     String?  // per-token prompt price (USD)
  completionPrice String?  // per-token completion price (USD)
  isRecommended   Boolean  @default(false) // shown under "RECOMMENDED" header
  aiSuggest       Boolean  @default(false) // shows "AI Suggest" sub-label
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// API keys generated by users for programmatic scan access.
model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   // user-given label, e.g. "CI Pipeline"
  keyPrefix   String   // first 8 chars shown in UI, e.g. "sp_live_"
  hashedKey   String   @unique // bcrypt hash of the full key
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

// Email notifications sent through the platform (mock — no real SMTP).
model EmailLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  to        String
  subject   String
  body      String
  status    String   @default("SENT") // SENT | FAILED | PENDING
  createdAt DateTime @default(now())

  @@index([userId])
}
